---
// Batch detail page
import { prisma } from "@/lib/db";
import { Navbar } from "../components/Navbar";
import { BatchUpdatesList } from "../components/batch-updates/BatchUpdatesList";
import { renderLabelToBlob } from "@/lib/label-capture";

const id = Astro.url.pathname.split("/batches/")[1];
if (!id) {
  return Astro.redirect("/404");
}

const batch = await prisma.batch.findUnique({
  where: { id },
  include: {
    recipe: { select: { id: true, name: true, brewType: true } },
    ingredients: {
      include: {
        ingredient: { select: { name: true, defaultPrice: true } },
        recipeIngredient: { select: { amount: true, unit: true } },
      },
    },
  },
});

if (!batch) {
  return Astro.redirect("/404");
}

const updates = await prisma.batchUpdate.findMany({
  where: { batchId: batch.id },
  orderBy: { timestamp: "desc" },
});

const statusColors: Record<string, string> = {
  PLANNING: "badge-info",
  FERMENTING: "badge-warning",
  CONDITIONING: "badge-accent",
  BOTTLED: "badge-success",
  COMPLETE: "badge-primary",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{batch.recipe.name} - Batch - Brew Buddy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Limelight&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-base-200 print:bg-white print:text-black">
    <Navbar pathname={`/batches/${id}`} />
    <main class="flex-1 w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 print:p-0">
      <div class="max-w-3xl mx-auto">
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-1">
            <h1 class="text-2xl font-bold text-base-content">{batch.recipe.name}</h1>
            <span class="text-sm text-base-content/50 uppercase">{batch.recipe.brewType}</span>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class={`badge ${(statusColors as any)[batch.status] || "badge-ghost"}`}>
              {batch.status}
            </span>
            <span class="text-xs text-base-content/50">
              Created {new Date(batch.createdAt).toLocaleDateString()}
            </span>
          </div>
        </div>

        <div class="card bg-base-100 shadow-lg border border-base-300 mb-6">
          <div class="card-body">
            <h2 class="card-title">Batch Details</h2>
            <div class="grid grid-cols-2 gap-4 mt-2">
              <div>
                <span class="text-xs text-base-content/50">Start Date</span>
                <p>{batch.startDate ? new Date(batch.startDate).toLocaleDateString() : "\u2014"}</p>
              </div>
              {batch.endDate && (
                <div>
                  <span class="text-xs text-base-content/50">End Date</span>
                  <p>{new Date(batch.endDate).toLocaleDateString()}</p>
                </div>
              )}
              {batch.batchSize && (
                <div>
                  <span class="text-xs text-base-content/50">Batch Size</span>
                  <p>{batch.batchSize} liters</p>
                </div>
              )}
              {batch.ogReading && (
                <>
                  <div>
                    <span class="text-xs text-base-content/50">OG</span>
                    <p>{batch.ogReading}</p>
                  </div>
                  <div>
                    <span class="text-xs text-base-content/50">Est. ABV</span>
                    <p>{((batch.ogReading - 1.0) * 131.25).toFixed(1)}%</p>
                  </div>
                </>
              )}
              {batch.fgReading && (
                <div>
                  <span class="text-xs text-base-content/50">FG</span>
                  <p>{batch.fgReading}</p>
                </div>
              )}
              {batch.currentGravity && (
                <div>
                  <span class="text-xs text-base-content/50">Current Gravity</span>
                  <p>{batch.currentGravity}</p>
                </div>
              )}
            </div>
            {batch.notes && (
              <div class="mt-4">
                <span class="text-xs text-base-content/50">Batch Notes</span>
                <p class="text-sm mt-1 whitespace-pre-wrap">{batch.notes}</p>
              </div>
            )}
            <div class="divider my-2" />
            <div class="grid grid-cols-2 gap-2">
              <a href={`/batches/${id}/edit`} class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-3.438a4.5 4.5 0 0 1 1.13-1.897Z" />
                </svg>
                Edit Batch
              </a>
              <form
                onSubmit={(e) => {
                  e.preventDefault();
                  window.location.href = `/batches/${id}/label`;
                }}
                class="inline"
              >
                <button type="submit" class="btn btn-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H4.125m15.375 0h-9M3.375 19.5h17.25m-2.625-3.75H6" />
                  </svg>
                  Download Label
                </button>
              </form>
            </div>
          </div>
        </div>

        {batch.ingredients && batch.ingredients.length > 0 && (
          <div class="card bg-base-100 shadow-lg border border-base-300 mb-6">
            <div class="card-body">
              <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12.07c.21 2.006-.34 3.439-2.073 4.194-.513.181-2.007.478-4.614.883-6.014.946-9.415.896-9.508.894a.849.849 0 0 1-.8-.349 5.124 5.124 0 0 1-.71-3.865l1.263-12.07C2.624 5.103 3.84 4.25 5.213 4.25h13.574c1.373 0 2.589.854 3.004 2.257Z" />
                </svg>
                Ingredients & Cost
              </h2>
              <div class="overflow-x-auto">
                <table class="table table-sm">
                  <thead>
                    <tr class="border-base-300">
                      <th class="w-1/3">Ingredient</th>
                      <th class="w-24">Amount</th>
                      <th class="w-32">Unit Price (&pound;)</th>
                      <th class="w-24 text-right">Cost</th>
                    </tr>
                  </thead>
                  <tbody>
                    {batch.ingredients.map((bi: any) => {
                      const unitPrice = bi.price ?? bi.ingredient.defaultPrice ?? 0;
                      const cost = unitPrice * bi.recipeIngredient.amount;
                      return (
                        <tr key={bi.id} class="border-base-200">
                          <td class="font-medium">{bi.ingredient.name}</td>
                          <td class="text-sm text-base-content/70">{bi.recipeIngredient.amount} {bi.recipeIngredient.unit}</td>
                          <td class="text-sm text-base-content/70">&pound;{unitPrice.toFixed(2)}</td>
                          <td class="text-right font-mono text-sm">&pound;{cost.toFixed(2)}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                  <tfoot>
                    <tr class="border-primary font-bold border-t-2">
                      <td colspan={3} class="text-right pr-4">Total Ingredient Cost:</td>
                      <td class="text-lg">
                        &pound;{batch.ingredients
                          .reduce((sum: number, bi: any) => {
                            const unitPrice = bi.price ?? bi.ingredient.defaultPrice ?? 0;
                            return sum + unitPrice * bi.recipeIngredient.amount;
                          }, 0)
                          .toFixed(2)}
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
        )}

        <div class="card bg-base-100 shadow-lg border border-base-300 print:hidden">
          <div class="card-body">
            <h2 class="card-title mb-4">
              Updates
              <span class="badge badge-ghost badge-sm">{updates.length}</span>
            </h2>

            <div class="divider my-6">
              <div class="flex items-center gap-2 text-base-content/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 3 2.25 2.25-1.121 1.122A2.25 2.25 0 0 1 7.43 7.09 2.25 2.25 0 0 1 6.75 5.828Zm6.22-1.947.943.943a2.25 2.25 0 0 1-1.479 3.833c-.418.046-.837.115-1.253.205l-.347.089a4.483 4.483 0 0 0-3.212 3.212l-.089.347A9.97 9.97 0 0 0 8.25 20.25 8 8 0 0 0 9.158 21h5.684a8 8 0 0 0 4.627-1.719 9.97 9.97 0 0 0 2.596-4.832l-.089-.347a4.483 4.483 0 0 0-3.212-3.212l-.347-.089a2.25 2.25 0 0 1-1.253-3.833l.943-.943" />
                </svg>
                <span class="text-sm">History</span>
              </div>
            </div>

            <BatchUpdatesList updates={updates} />
          </div>
        </div>
      </div>
    </main>
  </body>
</html>

<script client:load is:html>
  interface UpdateItem {
    id: string;
    batchId: string;
    timestamp: string;
    notes?: string | null;
    image?: string | null;
    createdAt: string;
    updatedAt: string;
  }

  function BatchUpdatesList({ updates }: { updates: UpdateItem[] }) {
    if (!updates || updates.length === 0) {
      return (
        <div class="text-center py-8 text-base-content/40">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mx-auto mb-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          <p class="text-sm">No updates yet</p>
        </div>
      );
    }

    return (
      <div class="space-y-4">
        {updates.map((update) => (
          <div key={update.id} class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 rounded-full bg-primary mt-1.5" />
              <div class="w-px flex-1 bg-base-content/10 my-1" />
            </div>
            <div class="flex-1 pb-6">
              <div class="flex items-center gap-2 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-base-content/50">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
                <span class="text-xs text-base-content/50">
                  {new Date(update.timestamp).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </span>
              </div>
              {update.image && (
                <div class="mt-2 mb-2">
                  <img src={update.image} alt="Batch update" class="max-w-xs rounded-lg border border-base-200" />
                </div>
              )}
              {update.notes && (
                <p class="text-sm text-base-content/80 whitespace-pre-wrap">{update.notes}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    );
  }
</script>
